# Secrets below are required at runtime (once Phase 1+ wires them into config).
# Copy to .env and fill in real values. Never commit .env.

PORT=4000
NODE_ENV=development

SESSION_SECRET=change-me-to-a-long-random-string
PLEX_CLIENT_ID=change-me-plex-client-id
PLEX_PRODUCT=Tyflix
PLEX_BASEURL=http://plex:32400
PLEX_TOKEN=change-me-plex-token
SEERR_URL=http://seerr:5055
SEERR_API_KEY=change-me-seerr-api-key
DASHBOARD_URL=http://<SERVER_LAN_IP>:8787
