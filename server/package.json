{
  "name": "@tyflix/server",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsc && concurrently -k -n tsc,node -c blue,cyan \"tsc -w --preserveWatchOutput\" \"node --watch dist/index.js\"",
