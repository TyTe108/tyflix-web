    "start": "node dist/index.js",
    "test": "npm run build && node --test \"dist/**/*.test.js\""
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/node": "22.15.32",
    "concurrently": "9.2.1",
    "typescript": "5.8.3"
  }
}
